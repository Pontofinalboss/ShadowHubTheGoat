RunService.RenderStepped:Connect(function()
    local ch=LocalPlayer.Character; if not ch then return end
    local hm=ch:FindFirstChildOfClass("Humanoid")
    local rt=ch:FindFirstChild("HumanoidRootPart")
    if not hm or not rt then return end

    -- Basic protections
    if T.NoStun then pcall(function() hm.WalkSpeed=math.max(hm.WalkSpeed, 31) end) end
    if T.AntiRagdoll then pcall(function() hm:SetStateEnabled(Enum.HumanoidStateType.Ragdoll,false) end) end
    if T.RagdollCancel then pcall(function() local st=hm:GetState(); if st==Enum.HumanoidStateType.FallingDown or st==Enum.HumanoidStateType.Ragdoll then hm:ChangeState(Enum.HumanoidStateType.GettingUp) end end) end

    -- AutoBlock logic
    if T.AutoBlockOnly then pcall(function() local np=GetNearest(C.BlockDist); if np then HoldKey(Enum.KeyCode.F, 0.5) end end) end
    if T.AutoBlockAttack then pcall(function() local np=GetNearest(C.BlockDist); if np and np.Character then local atk,trk=IsEnemyAttacking(np,C.BlockDist); if atk then HoldKey(Enum.KeyCode.F, 0.5); task.delay(0.52, DoM1) end end end) end
    if T.AutoParry then pcall(function() local np=GetNearest(C.BlockDist); if np and np.Character then local atk=IsEnemyAttacking(np,C.BlockDist); if atk then HoldKey(Enum.KeyCode.F, 0.12); task.delay(0.14, DoM1) end end end) end

    -- Phase 2 behaviors already implemented earlier
    -- AutoDodge
    if T.AutoDodge then
        pcall(function()
            local now = tick()
            if now - LastDodgeTime >= C.AutoDodgeCD then
                local np = GetNearest(15)
                if np and np.Character then
                    local atk = IsEnemyAttacking(np, 15)
                    if atk then
                        local er = np.Character:FindFirstChild("HumanoidRootPart")
                        if er and RootPart then
                            LastDodgeTime = now
                            local behindPos = er.Position - (er.CFrame.LookVector * 4)
                            pcall(function() RootPart.CFrame = CFrame.new(behindPos + Vector3.new(0,3,0)) end)
                        end
                    end
                end
            end
        end)
    end

    -- ComboBreaker
    if T.ComboBreaker and hm then pcall(function() local curHP = hm.Health; if curHP < (LastHP - 2) and curHP>0 and RootPart then local right = Workspace.CurrentCamera and Workspace.CurrentCamera.CFrame.RightVector or Vector3.new(1,0,0); local dir = (math.random()>0.5) and right or -right; local newPos = RootPart.Position + dir * 12; pcall(function() RootPart.CFrame = CFrame.new(newPos) end) end end) end
    LastHP = hm.Health or LastHP

    -- TargetLock
    if T.TargetLock and RootPart then pcall(function() local np = GetNearest(100); if np and np.Character then local er = np.Character:FindFirstChild("HumanoidRootPart"); if er then local cam = Workspace.CurrentCamera; if cam then cam.CFrame = CFrame.new(cam.CFrame.Position, er.Position) end; RootPart.CFrame = CFrame.new(RootPart.Position, Vector3.new(er.Position.X, RootPart.Position.Y, er.Position.Z)) end end end) end

    -- VoidTrap detection
    MaybeActivateVoidTrap()

    -- FakeLag
    if T.FakeLag and hm.MoveDirection.Magnitude>0 then
        StartFakeLagOnce()
    end

    -- AutoEvasion
    if T.AutoEvasion and hm.Health < hm.MaxHealth*(C.HealthAlertThreshold/100) and hm.Health>0 then
        DoAutoEvasion()
    end

    -- Anti-Void
    HandleAntiVoid()

    -- Invisible mode: keep camera fixed while body under ground
    if T.Invisible then
