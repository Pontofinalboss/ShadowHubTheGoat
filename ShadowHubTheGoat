local TI = TweenInfo.new
local function Tw(o, ti, p) pcall(function() TweenService:Create(o,ti,p):Play() end) end

local function GetNearest(maxD)
    maxD = maxD or 200; local best, bestD = nil, maxD
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local r = p.Character:FindFirstChild("HumanoidRootPart")
            local h = p.Character:FindFirstChildOfClass("Humanoid")
            if r and h and h.Health > 0 and RootPart then
                local d = (RootPart.Position - r.Position).Magnitude
                if d < bestD then best = p; bestD = d end
            end
        end
    end
    return best, bestD
end

local function PressKey(kc)
    pcall(function()
        local v = game:GetService("VirtualInputManager")
        v:SendKeyEvent(true, kc, false, game)
        task.delay(0.08, function() v:SendKeyEvent(false, kc, false, game) end)
    end)
end

local function HoldKey(kc, dur)
    pcall(function()
        local v = game:GetService("VirtualInputManager")
        v:SendKeyEvent(true, kc, false, game)
        task.delay(dur, function() v:SendKeyEvent(false, kc, false, game) end)
    end)
end

local function DoM1()
    pcall(function()
        local vim = game:GetService("VirtualInputManager")
        local cam = Workspace.CurrentCamera
        local cx, cy = cam.ViewportSize.X/2, cam.ViewportSize.Y/2
