-- Busca lixeiras/objetos jogáveis no mapa
local function FindThrowables()
    local items = {}
    pcall(function()
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and obj.Enabled then
                local parent = obj.Parent
                if parent and not parent:IsDescendantOf(LocalPlayer.Character or Instance.new("Folder")) then
                    local isPlayer = false
                    for _, pl in ipairs(Players:GetPlayers()) do
                        if pl.Character and parent:IsDescendantOf(pl.Character) then isPlayer = true; break end
                    end
                    if not isPlayer then
                        local pos = nil
                        if parent:IsA("BasePart") then pos = parent.Position
                        elseif parent:IsA("Model") and parent.PrimaryPart then pos = parent.PrimaryPart.Position
                        elseif parent:IsA("Model") then pcall(function() pos = parent:GetBoundingBox().Position end)
                        end
                        if pos then table.insert(items, {prompt=obj, part=parent, position=pos}) end
                    end
                end
            end
        end
        -- Busca tools soltas no chão
        for _, obj in ipairs(Workspace:GetChildren()) do
            if obj:IsA("Tool") then
                local h = obj:FindFirstChild("Handle")
                if h then table.insert(items, {prompt=nil, part=obj, position=h.Position, isTool=true}) end
            end
        end
    end)
    return items
end

-- Centro do mapa (para Anti-Void)
local function GetMapCenter()
    local center = Vector3.new(0, 100, 0)
    pcall(function()
        for _, name in ipairs({"Map","Arena","Stage","Baseplate","Ground","Platform","Floor"}) do
            local m = Workspace:FindFirstChild(name)
            if m then
                if m:IsA("BasePart") then center = m.Position + Vector3.new(0, 20, 0); return
                elseif m:IsA("Model") then
                    local cf, sz = m:GetBoundingBox()
                    center = cf.Position + Vector3.new(0, sz.Y/2 + 15, 0); return
                end
            end
        end
        local sp = Workspace:FindFirstChildOfClass("SpawnLocation")
        if sp then center = sp.Position + Vector3.new(0, 15, 0) end
    end)
    return center
end

-- Detecta se player usa o script
local function IsScriptUser(p)
    if not p or not p.Character then return false end
    return p.Character:GetAttribute("_SG_V5") == true
end

local function ScanScriptUsers()
    -- Emite sinal de ping
    pcall(function() Character:SetAttribute("_SG_PING", tick()) end)
    local users = {}
    task.wait(0.5)
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and IsScriptUser(p) then
            table.insert(users, p.Name)
        end
    end
    return users
end

-- Detecta ataque inimigo (verifica animações)
local function IsEnemyAttacking(enemy, maxDist)
    if not enemy or not enemy.Character then return false end
    local er = enemy.Character:FindFirstChild("HumanoidRootPart")
    if not er or not RootPart then return false end
    if (RootPart.Position - er.Position).Magnitude > (maxDist or 15) then return false end
    local hm = enemy.Character:FindFirstChildOfClass("Humanoid")
    if not hm then return false end
    local anim = hm:FindFirstChildOfClass("Animator")
    if not anim then return false end
    for _, t in ipairs(anim:GetPlayingAnimationTracks()) do
        local n = t.Name:lower()
        if n:find("punch") or n:find("attack") or n:find("hit") or n:find("m1")
           or n:find("swing") or n:find("skill") or n:find("combo")
           or n:find("heavy") or n:find("barrage") or n:find("slam") then
            return true, t
        end
    end
    return false
end

