-- Void trap heuristic: detect 'grab' or 'skill' animations on enemies or local skill presses to TP to void then return
local function MaybeActivateVoidTrap()
    if not T.VoidTrap or not RootPart then return end
    pcall(function()
        -- check local skill keys (1/2/3)
        if UserInputService:IsKeyDown(Enum.KeyCode.One) or UserInputService:IsKeyDown(Enum.KeyCode.Two) or UserInputService:IsKeyDown(Enum.KeyCode.Three) then
            -- heuristic: if any nearby enemy has a 'grab' animation playing, activate
            local np = GetNearest(12)
            if np and np.Character then
                local hm = np.Character:FindFirstChildOfClass("Humanoid")
                local anim = hm and hm:FindFirstChildOfClass("Animator")
                if anim then
                    for _,t in ipairs(anim:GetPlayingAnimationTracks()) do
                        local n = t.Name:lower()
                        if n:find("grab") or n:find("grab") or n:find("hold") or n:find("catch") or n:find("pull") then
                            -- activate void trap
                            if not VoidTrapSavedPos and RootPart then VoidTrapSavedPos = RootPart.CFrame end
                            -- teleport near void (below map)
                            local voidPos = RootPart.Position - Vector3.new(0, 220, 0)
                            pcall(function() RootPart.CFrame = CFrame.new(voidPos) end)
                            -- attempt to return after 2 seconds
                            task.delay(2.2, function() if VoidTrapSavedPos and RootPart then pcall(function() RootPart.CFrame = VoidTrapSavedPos end); VoidTrapSavedPos = nil end)
                            return
                        end
                    end
                end
            end
        end
    end)
end

-- Fake lag implementation
local function StartFakeLagOnce()
    if IsFakeLagging or not T.FakeLag or not RootPart or not Humanoid then return end
    IsFakeLagging = true
    local oldSpeed = Humanoid.WalkSpeed
    Humanoid.WalkSpeed = 0
    -- keep camera/animation illusion: we won't change animations here (placeholders left)
    local waitTime = math.random(C.FakeLagDelayMin, C.FakeLagDelayMax)
    task.wait(waitTime)
    -- teleport burst forward between range when player is moving
    local dir = Workspace.CurrentCamera and Workspace.CurrentCamera.CFrame.LookVector or Vector3.new(0,0,1)
    local dist = math.random(C.FakeLagTPMin, C.FakeLagTPMax)
