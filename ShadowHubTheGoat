local function TeleportWithBV(targetPos, duration)
    -- Gentle teleport with BodyVelocity to preserve physics feel
    if not RootPart then return end
    local bv = Instance.new("BodyVelocity", RootPart)
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = (targetPos - RootPart.Position) / math.max(duration or 0.12, 0.01)
    Debris:AddItem(bv, duration or 0.12)
    task.delay((duration or 0.12), function() pcall(function() RootPart.CFrame = CFrame.new(targetPos) end) end)
end

-- Dash implementation: press Q to dash based on held movement keys (A/D/S)
local function DoDash()
    if not RootPart then return end
    local cam = Workspace.CurrentCamera
    local dir = Vector3.new(0,0,0)
    local isLeft = UserInputService:IsKeyDown(Enum.KeyCode.A)
    local isRight = UserInputService:IsKeyDown(Enum.KeyCode.D)
    local isBack = UserInputService:IsKeyDown(Enum.KeyCode.S)
    if isLeft then
        dir = -cam.CFrame.RightVector
    elseif isRight then
        dir = cam.CFrame.RightVector
    elseif isBack then
        dir = -cam.CFrame.LookVector
    else
        dir = cam.CFrame.LookVector
    end
    local dist = (isBack and C.DashDistBack) or C.DashDistSide
    local target = RootPart.Position + Vector3.new(dir.X, 0, dir.Z).Unit * dist
    -- play dash: temporary BodyVelocity + BodyGyro to align
    local bv = Instance.new("BodyVelocity", RootPart)
    bv.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    bv.Velocity = Vector3.new(dir.X, 0, dir.Z).Unit * (dist * 60)
    local bg = Instance.new("BodyGyro", RootPart)
    bg.MaxTorque = Vector3.new(1e5,1e5,1e5)
    bg.CFrame = CFrame.new(RootPart.Position, RootPart.Position + dir)
    Debris:AddItem(bv, 0.12)
    Debris:AddItem(bg, 0.12)
    task.delay(0.12, function() pcall(function() RootPart.CFrame = CFrame.new(target + Vector3.new(0,3,0)) end) end)
end

