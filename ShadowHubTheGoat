-- Auto Evasion for mobile + desktop
local function DoAutoEvasion()
    if not T.AutoEvasion or not Humanoid or Humanoid.Health<=0 then return end
    local np = GetNearest(30)
    if np and np.Character and RootPart then
        -- choose side away from enemy
        local er = np.Character:FindFirstChild("HumanoidRootPart")
        if er then
            local away = (RootPart.Position - er.Position).Unit
            local right = Workspace.CurrentCamera and Workspace.CurrentCamera.CFrame.RightVector or Vector3.new(1,0,0)
            local sideDir = (math.abs(away:Dot(right)) > 0.5) and Vector3.new(right.X,0,right.Z) or (away + right).Unit
            local target = RootPart.Position + Vector3.new(sideDir.X,0,sideDir.Z).Unit * C.DashDistSide
            pcall(function() RootPart.CFrame = CFrame.new(target + Vector3.new(0,3,0)) end)
        end
    else
        -- fallback: simple backward dash
        pcall(DoDash)
    end
end

