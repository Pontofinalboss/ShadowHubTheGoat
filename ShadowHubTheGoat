-- Render loop: add improved AutoBlock / AutoBlockAttack / AutoParry logic
-- ============================================================
RunService.RenderStepped:Connect(function()
    local ch=LocalPlayer.Character; if not ch then return end
    local hm=ch:FindFirstChildOfClass("Humanoid")
    local rt=ch:FindFirstChild("HumanoidRootPart")
    if not hm or not rt then return end

    -- AUTO BLOCK ONLY: hold F for 0.5s when enemy attacking
    if T.AutoBlockOnly then pcall(function() local np=GetNearest(C.BlockDist); if np then HoldKey(Enum.KeyCode.F, 0.5) end end) end

    -- AUTO BLOCK ATTACK: detect enemy attack → block (0.5s) → attack
    if T.AutoBlockAttack then
        pcall(function()
            local np = GetNearest(C.BlockDist)
            if np and np.Character and RootPart then
                local atk, trk = IsEnemyAttacking(np, C.BlockDist)
                if atk then
                    -- start block for 0.5s (non-blocking)
                    HoldKey(Enum.KeyCode.F, 0.5)
                    -- schedule attack shortly after block window
                    task.delay(0.52, function()
                        pcall(DoM1)
                    end)
                end
            end
        end)
    end

    -- AUTO PARRY: detect enemy attack → quick parry window (~0.12s) → counter
    if T.AutoParry then
        pcall(function()
            local np = GetNearest(C.BlockDist)
            if np and np.Character and RootPart then
                local atk = IsEnemyAttacking(np, C.BlockDist)
                if atk then
                    HoldKey(Enum.KeyCode.F, 0.12)
                    task.delay(0.14, function()
                        pcall(DoM1)
                    end)
                end
            end
        end)
    end

    -- (Other existing behaviors continue unchanged...)

end)

