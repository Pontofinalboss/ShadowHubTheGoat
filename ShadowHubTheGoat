-- Trash farm implementation (simplified, follows your described flow)
local function RunTrashFarm()
    if not T.TrashFarm or not RootPart then return end
    task.spawn(function()
        while T.TrashFarm do
            -- find a target with <=35% HP
            local target = nil
            for _, p in ipairs(Players:GetPlayers()) do
                if p~=LocalPlayer and p.Character then
                    local hm = p.Character:FindFirstChildOfClass("Humanoid")
                    if hm and hm.Health>0 and hm.Health/hm.MaxHealth <= 0.35 then target = p; break end
                end
            end
            if not target then task.wait(1); continue end
            -- teleport to each trash point and click
            local picked = false
            for _,pos in ipairs(C.TrashPoints) do
                pcall(function() RootPart.CFrame = CFrame.new(pos + Vector3.new(0,3,0)) end)
                task.wait(0.5)
                -- click
                DoM1()
                task.wait(0.2)
                -- check if we picked something: look for any Tool in Backpack or Character
                local foundTool = false
                pcall(function()
                    for _,it in ipairs(LocalPlayer.Backpack:GetChildren()) do if it:IsA("Tool") then foundTool=true; break end end
                    for _,it in ipairs(LocalPlayer.Character:GetChildren()) do if it:IsA("Tool") then foundTool=true; break end end
                end)
                if foundTool then
                    picked = true; break
                end
            end
            if picked then
                -- return behind enemy and attack repeatedly until death
                if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
                    local tr = target.Character.HumanoidRootPart
                    pcall(function() RootPart.CFrame = tr.CFrame - tr.CFrame.LookVector*6 end)
                    -- attack loop
                    while target and target.Character and target.Character:FindFirstChildOfClass("Humanoid") and target.Character:FindFirstChildOfClass("Humanoid").Health>0 and T.TrashFarm do
                        DoM1(); task.wait(0.6)
                    end
                end
            else
                -- if nothing happened, spawn temporary visual platform at first trash point and wait 10s
                local pt = C.TrashPoints[1]
                if pt then
                    local p = Instance.new("Part", Workspace); p.Anchored=true; p.Size=Vector3.new(30,1,30); p.Position = pt; p.Transparency=0.5; p.BrickColor=BrickColor.new("Really black")
                    Debris:AddItem(p, 10)
                    task.wait(10)
                end
            end
            task.wait(0.5)
        end
    end)
end

